{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Adicionado para garantir que os tipos do Vite sejam carregados */
    "types": ["vite/client"]
  },
  "include": ["src", "vite-env.d.ts"], // <-- GARANTE A INCLUSÃO DO ARQUIVO DE TIPOS
  "references": [{ "path": "./tsconfig.node.json" }]
}
