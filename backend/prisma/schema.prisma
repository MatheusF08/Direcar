generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          Int        @id @default(autoincrement())
  companyName String
  name        String
  email       String     @unique
  password    String
  createdAt   DateTime   @default(now())
  estimates   Estimate[]
}

model Estimate {
  id              Int      @id @default(autoincrement())
  mechanicName    String
  observations    String?
  totalPrice      Float
  status          String   @default("AG_APROVACAO")
  createdAt       DateTime @default(now())
  statusUpdatedAt DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  userId    Int
  vehicle   Vehicle?
  parts     Part[]
  services  Service[]
}

model Vehicle {
  id          Int      @id @default(autoincrement())
  clientName  String
  clientPhone String
  plate       String   @unique
  brand       String
  model       String
  year        Int
  
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  estimateId  Int      @unique
}

model Part {
  id          Int      @id @default(autoincrement())
  description String
  quantity    Int
  unitPrice   Float
  commission  Float
  
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  estimateId  Int
}

model Service {
  id               Int      @id @default(autoincrement())
  description      String
  mechanicExecutor String
  price            Float
  commission       Float
  
  estimate         Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  estimateId       Int
}
